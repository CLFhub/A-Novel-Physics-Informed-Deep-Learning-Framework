import torch
import torch.nn as nn

class ResTransNet(nn.Module):  
    def __init__(self, basicblock, blocks_num):
        super().__init__()
        self.in_channel = 64
        self.conv1 = nn.Conv2d(3, self.in_channel, kernel_size=3, stride=1, bias=False, padding=1)
        self.bn1 = nn.BatchNorm2d(self.in_channel)
        self.relu = nn.ReLU()
        self.maxpool = nn.MaxPool2d(kernel_size=3, stride=1, padding=1)
        self.layer1 = self._make_layer(basicblock, 64, blocks_num[0], stride=1)
        self.layer2 = self._make_layer(basicblock, 128, blocks_num[1], stride=2)
        self.layer3 = self._make_layer(basicblock, 256, blocks_num[2], stride=2)
        self.layer4 = self._make_layer(basicblock, 512, blocks_num[3], stride=2)
